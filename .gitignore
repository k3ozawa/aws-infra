# ==============================================================
# SECURITY: 絶対にコミットしてはいけないファイル
# ==============================================================

# Terraform シークレット・状態ファイル
*.tfvars
*.tfvars.json
*.tfstate
*.tfstate.backup
.terraform/

# 環境変数・認証情報
.env
.env.*

# mise アカウント固有設定（プロファイル名等を含むため）
terraform/**/.mise.toml
*.pem
*.key

# ==============================================================
# Terraform 生成ファイル
# ==============================================================
.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ==============================================================
# macOS
# ==============================================================
.DS_Store

# ==============================================================
# IDE / エディタ
# ==============================================================
.idea/
.vscode/
*.swp
*.swo
